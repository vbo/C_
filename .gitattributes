# Default: normalize all text files to LF in the repository
* text=auto eol=lf

# Explicit rules for C_ files (ensures perfect consistency)
*.cs      text eol=lf
*.csproj  text eol=lf
*.sln     text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.xml     text eol=lf
*.sh      text eol=lf
*.ps1     text eol=lf

# Binary files (never touch line endings)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.exe     binary
*.dll     binary
*.pdb     binary